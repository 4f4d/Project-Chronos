# Project Chronos - Backend Environment Configuration
# Copy this file to .env and fill in values as needed

# ============================================================
# SERVER CONFIGURATION
# ============================================================
HOST=0.0.0.0
PORT=8000

# ============================================================
# PIPELINE CONFIGURATION
# ============================================================
# Delay in seconds between patient vital updates in the simulator
STREAM_INTERVAL_SECONDS=5.0

# Maximum number of patient records to simulate concurrently
MAX_CONCURRENT_PATIENTS=20

# Path to the saved trained models directory
MODELS_DIR=./models

# Path to the downloaded datasets
DATA_DIR=./data

# ============================================================
# PREDICTION THRESHOLDS
# Probability above which a patient is flagged as HIGH RISK
# ============================================================
SEPSIS_RISK_THRESHOLD=0.60
HYPOTENSION_RISK_THRESHOLD=0.55
# Bug 50 fix: target renamed from cardiac_arrest to hemodynamic_collapse on 2026-02-26
# Old key CARDIAC_ARREST_RISK_THRESHOLD is now HEMODYNAMIC_COLLAPSE_RISK_THRESHOLD
HEMODYNAMIC_COLLAPSE_RISK_THRESHOLD=0.50

# ============================================================
# PHYSICS ENGINE THRESHOLDS
# ============================================================
# Oxygen delivery critical threshold in mL O2/min/m2
DO2_CRITICAL_THRESHOLD=330.0
# Hemodynamic instability score above which cardiac arrest alert fires
HEMODYNAMIC_INSTABILITY_THRESHOLD=0.75
