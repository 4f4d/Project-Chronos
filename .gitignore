# ============================================================================
# Project Chronos — .gitignore
# ============================================================================

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ----------------------------------------------------------------------------
# Virtual environments
# ----------------------------------------------------------------------------
backend/.venv/
.venv/
venv/
env/

# ----------------------------------------------------------------------------
# Datasets (large, publicly available — download instructions in README)
# ----------------------------------------------------------------------------
backend/data/

# ----------------------------------------------------------------------------
# Training logs (contain intermediate debug output)
# ----------------------------------------------------------------------------
backend/logs/

# ----------------------------------------------------------------------------
# Feature caches (large parquet files, regenerated during training)
# ----------------------------------------------------------------------------
backend/models/**/_features_cache_*.parquet

# ----------------------------------------------------------------------------
# Training checkpoints (fold-level intermediates, not needed for inference)
# ----------------------------------------------------------------------------
backend/models/*/checkpoints/

# ----------------------------------------------------------------------------
# Node.js
# ----------------------------------------------------------------------------
frontend/node_modules/
.npm-cache/

# ----------------------------------------------------------------------------
# Build artifacts
# ----------------------------------------------------------------------------
frontend/dist/

# ----------------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ----------------------------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------------------------
.vscode/
.idea/
*.iml

# ----------------------------------------------------------------------------
# Environment files with secrets
# ----------------------------------------------------------------------------
.env
!backend/.env.example
!frontend/.env

# ----------------------------------------------------------------------------
# Presentation PDFs (too large for repo, shared separately)
# ----------------------------------------------------------------------------
*.pdf

# ----------------------------------------------------------------------------
# Previous model metadata (only current model_metadata.json is needed)
# ----------------------------------------------------------------------------
backend/models/*/model_metadata_prev.json

# ----------------------------------------------------------------------------
# Temporary and scratch files
# ----------------------------------------------------------------------------
*.tmp
*.bak
*.orig
